{
    "name": "json-editor",
    "license": "MIT",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "code:analyze": "pnpm run code:bundle --analyze",
        "code:bundle": "NODE_ENV=production PACKAGE_NAME=rje-code-widgets rspack build",
        "code:dist": "rm -rf packages/rje-code-widgets/dist; pnpm run code:bundle; pnpm run code:ts",
        "code:ts": "(cd packages/rje-code-widgets && tsc --build .)",
        "dist": "rm -rf packages/*/dist; pnpm run hje:dist; pnpm run rje:dist; pnpm run mantine:dist; pnpm run code:dist;",
        "docs": "storybook dev -p 6006",
        "docs:dist": "storybook build --output-dir ./dist/docs",
        "hje:analyze": "pnpm run hje:bundle --analyze",
        "hje:bundle": "NODE_ENV=production PACKAGE_NAME=headless-json-editor rspack build",
        "hje:dist": "rm -rf packages/headless-json-editor/dist; pnpm run hje:bundle; pnpm run hje:ts",
        "hje:ts": "(cd packages/headless-json-editor && tsc --outDir dist --target ES2019 --declaration --noEmit false)",
        "lint": "eslint .",
        "mantine:analyze": "pnpm run mantine:bundle --analyze",
        "mantine:bundle": "NODE_ENV=production PACKAGE_NAME=rje-mantine-widgets rspack build",
        "mantine:dist": "rm -rf packages/rje-mantine-widgets/dist; pnpm run mantine:bundle; pnpm run mantine:ts",
        "mantine:ts": "(cd packages/rje-mantine-widgets && tsc --build .)",
        "publish-all": "node ./tools/publish.js",
        "rje:analyze": "pnpm run rje:bundle --analyze",
        "rje:bundle": "NODE_ENV=production PACKAGE_NAME=react-json-editor rspack build",
        "rje:dist": "rm -rf packages/react-json-editor/dist; pnpm run rje:bundle; pnpm run rje:ts",
        "rje:ts": "(cd packages/react-json-editor && tsc --build .)",
        "set-version": "node ./tools/version.js",
        "test": "pnpm run test:unit; pnpm run test:stories",
        "test:ci": "jest --maxWorkers=2 --ci --reporters=default --reporters=jest-junit",
        "test:coverage": "pnpm run test --collect-coverage",
        "test:stories": "test-storybook",
        "test:stories:ci": "JEST_JUNIT_OUTPUT_FILE=storybook-test-results.xml test-storybook --ci --junit",
        "test:unit": "jest --maxWorkers=2 --verbose"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-react": "^7.28.5",
        "@babel/preset-typescript": "^7.28.5",
        "@codemirror/autocomplete": "^6.18.3",
        "@codemirror/lang-json": "*",
        "@codemirror/language": "^6.10.5",
        "@codemirror/lint": "^6.9.4",
        "@codemirror/state": "^6.4.1",
        "@codemirror/view": "^6.38.1",
        "@eslint/js": "^10.0.1",
        "@mantine/core": "^8.3.14",
        "@mantine/dates": "^8.3.14",
        "@mantine/hooks": "^8.3.14",
        "@sagold/json-pointer": "^7.2.1",
        "@types/uuid": "^10.0.0",
        "@uiw/react-codemirror": "^4.25.4",
        "classnames": "^2.5.1",
        "dayjs": "^1.11.20",
        "dayjs-plugin-utc": "^0.1.2",
        "fast-equals": "^6.0.0",
        "json-schema-library": "^11.3.1",
        "markdown-to-jsx": "^9.7.4",
        "short-unique-id": "^5.3.2",
        "sortablejs": "^1.15.7",
        "@rspack/cli": "^1.7.6",
        "@rspack/core": "^1.7.6",
        "@rspack/plugin-react-refresh": "^1.6.1",
        "@storybook/addon-docs": "^10.2.8",
        "@storybook/addon-links": "^10.2.8",
        "@storybook/react-vite": "^10.2.8",
        "@storybook/test-runner": "^0.24.2",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^ 6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/node": "25.2.3",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "concurrently": "^9.2.1",
        "css-loader": "^7.1.3",
        "deepmerge": "^4.3.1",
        "eslint": "10.0.0",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-no-unsanitized": "4.1.4",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-storybook": "^10.2.8",
        "globals": "^17.3.0",
        "http-server": "^14.1.1",
        "jest": "^30.2.0",
        "jest-environment-jsdom": "^30.2.0",
        "jest-junit": "^16.0.0",
        "jiti": "^2.6.1",
        "prettier": "^3.8.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "resolve-url-loader": "^5.0.0",
        "sass-embedded": "^1.97.3",
        "sass-loader": "^16.0.7",
        "storybook": "10.2.8",
        "style-loader": "^4.0.0",
        "terser-webpack-plugin": "^5.3.16",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.55.0",
        "vite": "^7.3.1",
        "wait-on": "^9.0.4"
    },
    "resolutions": {
        "jackspeak": "2.1.1",
        "@codemirror/view": "^6.38.1",
        "@codemirror/state": "^6.4.1"
    },
    "packageManager": "pnpm@10.8.0"
}
