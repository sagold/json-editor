{
    "name": "json-editor",
    "license": "MIT",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "code:analyze": "pnpm run code:bundle --analyze",
        "code:bundle": "NODE_ENV=production PACKAGE_NAME=rje-code-widgets rspack build",
        "code:dist": "rm -rf packages/rje-code-widgets/dist; pnpm run code:bundle; pnpm run code:ts",
        "code:ts": "(cd packages/rje-code-widgets && tsc --build .)",
        "dist": "rm -rf packages/*/dist; pnpm run hje:dist; pnpm run rje:dist; pnpm run mantine:dist; pnpm run code:dist;",
        "docs": "storybook dev -p 6006",
        "docs:generateData": "tsx packages/doc-generator/src/generateData.ts",
        "docs:generateDocs": "tsx packages/doc-generator/src/generateDocs.ts",
        "docs:dist": "storybook build --output-dir ./dist/docs",
        "hje:analyze": "pnpm run hje:bundle --analyze",
        "hje:bundle": "NODE_ENV=production PACKAGE_NAME=headless-json-editor rspack build",
        "hje:dist": "rm -rf packages/headless-json-editor/dist; pnpm run hje:bundle; pnpm run hje:ts",
        "hje:ts": "(cd packages/headless-json-editor && tsc --outDir dist --target ES2019 --declaration --noEmit false)",
        "lint": "eslint .",
        "mantine:analyze": "pnpm run mantine:bundle --analyze",
        "mantine:bundle": "NODE_ENV=production PACKAGE_NAME=rje-mantine-widgets rspack build",
        "mantine:dist": "rm -rf packages/rje-mantine-widgets/dist; pnpm run mantine:bundle; pnpm run mantine:ts",
        "mantine:ts": "(cd packages/rje-mantine-widgets && tsc --build .)",
        "publish-all": "node ./tools/publish.js",
        "rje:analyze": "pnpm run rje:bundle --analyze",
        "rje:bundle": "NODE_ENV=production PACKAGE_NAME=react-json-editor rspack build",
        "rje:dist": "rm -rf packages/react-json-editor/dist; pnpm run rje:bundle; pnpm run rje:ts",
        "rje:ts": "(cd packages/react-json-editor && tsc --build .)",
        "set-version": "node ./tools/version.js",
        "test": "pnpm run test:unit; pnpm run test:stories",
        "test:ci": "jest --maxWorkers=2 --ci --reporters=default --reporters=jest-junit",
        "test:coverage": "pnpm run test --collect-coverage",
        "test:stories": "vitest --project=storybook --run",
        "test:stories:ci": "vitest --project=storybook --run --reporter junit --outputFile storybook-test-results.xml",
        "test:unit": "jest --maxWorkers=2 --verbose"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.29.7",
        "@babel/preset-react": "^7.29.7",
        "@babel/preset-typescript": "^7.29.7",
        "@eslint/js": "^10.0.1",
        "@mantine/core": "^9.3.0",
        "@rspack/cli": "^2.0.1",
        "@rspack/core": "^2.0.6",
        "@rspack/plugin-react-refresh": "^2.0.2",
        "@sagold/json-pointer": "^7.2.1",
        "@sagold/json-query": "^6.2.0",
        "@storybook/addon-docs": "^10.4.2",
        "@storybook/addon-links": "^10.4.2",
        "@storybook/addon-vitest": "10.4.2",
        "@storybook/react-vite": "^10.4.2",
        "@storybook/test-runner": "^0.24.4",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^ 6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/node": "25.2.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@types/react-syntax-highlighter": "^15.5.13",
        "@types/uuid": "^11.0.0",
        "classnames": "^2.5.1",
        "concurrently": "^10.0.3",
        "css-loader": "^7.1.3",
        "dayjs": "^1.11.21",
        "dayjs-plugin-utc": "^0.1.2",
        "deepmerge": "^4.3.1",
        "eslint": "10.4.1",
        "eslint-import-resolver-typescript": "4.4.5",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-no-unsanitized": "4.1.5",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-storybook": "^10.4.2",
        "fast-equals": "^6.0.0",
        "globals": "^17.6.0",
        "http-server": "^14.1.1",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1",
        "jest-junit": "^17.0.0",
        "jiti": "^2.7.0",
        "json-schema-library": "^11.5.1",
        "markdown-to-jsx": "^9.7.4",
        "playwright": "^1.60.0",
        "prettier": "^3.8.3",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "react-syntax-highlighter": "^16.1.1",
        "resolve-url-loader": "^5.0.0",
        "sass-embedded": "^1.97.3",
        "sass-loader": "17.0.0",
        "short-unique-id": "^5.3.2",
        "sortablejs": "^1.15.7",
        "storybook": "10.4.2",
        "style-loader": "^4.0.0",
        "terser-webpack-plugin": "^5.6.1",
        "ts-jest": "^29.4.11",
        "tslib": "^2.8.1",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.1",
        "vite": "^8.0.16",
        "wait-on": "^9.0.4",
        "vitest": "^4.1.8",
        "@vitest/browser-playwright": "^4.1.8",
        "@vitest/coverage-v8": "^4.1.8"
    },
    "resolutions": {
        "jackspeak": ">=2.1.1"
    },
    "packageManager": "pnpm@10.8.0"
}
